# Variables de entorno — App Fitness Casa v2
# Copia este archivo como .env y rellena los valores reales
# El archivo .env NUNCA debe subirse al repositorio

# ── Supabase ──
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ── Servicios internos (sin prefijo VITE_ para que no queden expuestos en el bundle) ──
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# ── Acceso Super Admin ──
VITE_SUPER_ADMIN_ID=tu-uuid-de-super-admin-aqui

# ── AI ──
VITE_GEMINI_API_KEY=tu-gemini-api-key-aqui

# ── Storage ──
VITE_SUPABASE_EXERCISE_MEDIA_BUCKET=exercise-media

# ── Conexión directa a BD (solo para migraciones locales, nunca en producción) ──
# DATABASE_URL=postgresql://...
# DIRECT_URL=postgresql://...
