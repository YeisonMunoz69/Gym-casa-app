{
  "model_name": "fatigue_decay",
  "model_version": "1.0.0",
  "description": "Modelo de decaimiento exponencial (Banister ATL) para fatiga muscular. Calibrado estad\u00edsticamente por grupo muscular usando joep89/weightlifting (721 sesiones reales). Produce un score continuo 0-100 por grupo muscular. Reemplaza los thresholds de 2 d\u00edas / 4 sets en useMuscleRecovery.ts.",
  "model_type": "banister_atl_exponential_decay",
  "formula": "fatiga(t) = sum(vol_i * exp(-days_since_i / tau)) / max_atl_p95 * 100",
  "dataset": "joep89/weightlifting",
  "frontend_usage": [
    "v2/src/features/dashboard/hooks/useMuscleRecovery.ts",
    "v2/src/features/dashboard/components/RecoveryBodyMap.tsx"
  ],
  "score_thresholds": {
    "exhausted_above": 39.3,
    "recovering_above": 9.2,
    "recovered_below": 9.2,
    "note": "Score continuo 0-100. >p66 = exhausted, p33-p66 = recovering, <p33 = recovered"
  },
